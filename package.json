{
  "name": "ummaya",
  "version": "0.2.2",
  "description": "Conversational multi-agent harness for Korean public-service channels",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "ummaya": "bin/ummaya"
  },
  "files": [
    "bin/ummaya",
    "assets/*.svg",
    "assets/*.gif",
    "assets/*.mp4",
    "src/ummaya/**",
    "prompts/**",
    "tui/src/**",
    "tui/package.json",
    "tui/tsconfig.json",
    "pyproject.toml",
    "bun.lock",
    "npm-shrinkwrap.json",
    "uv.lock",
    "docs/demo/**",
    "docs/plugins/security-review.md",
    "tests/fixtures/plugin_validation/checklist_manifest.yaml",
    "!**/.DS_Store",
    "!**/__pycache__/**",
    "!tui/src/**/__tests__/**",
    "!tui/src/**/*.test.ts",
    "!tui/src/**/*.test.tsx",
    "!tui/src/**/*.snap",
    "!src/ummaya/**/tests/**",
    "!src/ummaya/**/*.pyc"
  ],
  "scripts": {
    "demo:readme": "bash docs/demo/record-readme-demo.sh",
    "docs:dev": "cd docs-site && bun run dev",
    "docs:c4": "bash scripts/render_c4_diagrams.sh",
    "docs:generate": "uv run python scripts/docs_generate.py",
    "docs:check": "uv run python scripts/docs_generate.py --check && cd docs-site && bun run build",
    "docs:build": "cd docs-site && bun run build",
    "package:dry-run": "mkdir -p package-evidence && npm pack --dry-run --json > package-evidence/npm-pack-dry-run.json",
    "package:check": "npm run package:dry-run && node scripts/check-npm-package.mjs package-evidence/npm-pack-dry-run.json",
    "package:homebrew-cask": "node scripts/build-homebrew-cask-artifact.mjs --arch arm64 && node scripts/build-homebrew-cask-artifact.mjs --arch x64"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "npm@11.14.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/umyunsang/UMMAYA.git"
  },
  "bugs": {
    "url": "https://github.com/umyunsang/UMMAYA/issues"
  },
  "homepage": "https://ummaya-docs.pages.dev/",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "agentic-ai",
    "bun",
    "civic-tech",
    "korean-public-service",
    "llm-tools",
    "public-apis"
  ],
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@anthropic-ai/mcpb": "^2.1.2",
    "@anthropic-ai/sandbox-runtime": "^0.0.49",
    "@anthropic-ai/sdk": "^0.37.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1036.0",
    "@commander-js/extra-typings": "^12.1.0",
    "@growthbook/growthbook": "^1.6.5",
    "@grpc/grpc-js": "^1.14.3",
    "@inkjs/ui": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.215.0",
    "@opentelemetry/core": "^2.7.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.216.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.216.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.216.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.216.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.216.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.216.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@pdf-lib/fontkit": "^1.1.1",
    "ajv": "^8.18.0",
    "asciichart": "^1.5.25",
    "auto-bind": "^5.0.1",
    "axios": "^1.15.2",
    "bidi-js": "^1.0.3",
    "bundle": "file:./tui/src/runtime/bundle-package",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "color-diff-napi": "^0.0.1",
    "diff": "^9.0.0",
    "env-paths": "^4.0.0",
    "execa": "^9.6.1",
    "fuse.js": "^7.3.0",
    "google-auth-library": "^10.6.2",
    "highlight.js": "^11.11.1",
    "https-proxy-agent": "^9.0.0",
    "ignore": "^7.0.5",
    "ink": "npm:@jrichman/ink@6.6.9",
    "jsonc-parser": "^3.3.1",
    "lodash-es": "^4.18.1",
    "lru-cache": "^11.3.5",
    "marked": "^18.0.2",
    "p-map": "^7.0.4",
    "pdf-lib": "^1.17",
    "pdf-to-img": "^4",
    "picomatch": "^4.0.4",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-reconciler": "0.33.0",
    "semver": "^7.7.4",
    "shell-quote": "^1.8.3",
    "supports-hyperlinks": "^4.4.0",
    "tree-kill": "^1.2.2",
    "undici": "^8.1.0",
    "usehooks-ts": "^3.1.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "xss": "^1.0.15",
    "yaml": "^2.8.3",
    "zod": "^3.23.0"
  }
}
