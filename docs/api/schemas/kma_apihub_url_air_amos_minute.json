  "$id": "https://ummaya.example/api/schemas/kma_apihub_url_air_amos_minute.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "dtm": {
      "default": 60,
      "description": "Lookback window in minutes including tm. Official maximum is 60 minutes. Official parameter name: dtm. Operation: air_amos_minute.",
      "title": "Dtm",
      "type": "integer"
    },
    "help": {
      "default": 1,
      "description": "KMA APIHub URL request parameter help. Official parameter name: help. Operation: air_amos_minute.",
      "title": "Help",
      "type": "integer"
    },
    "stn": {
      "description": "Official AMOS station number. The APIHub page lists 110 Gimpo, 113 Incheon, 182 Jeju, 163 Muan, 151 Ulsan, 167 Yeosu, and 92 Yangyang. Gimhae is not listed for this AMOS endpoint; use METAR RKPK for Gimhae airport aviation weather. Official parameter name: stn. Operation: air_amos_minute.",
      "title": "Stn",
      "type": "string"
    },
    "tm": {
      "anyOf": [
        {
          "pattern": "^\\d{12}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "AMOS lookup time in KST, YYYYMMDDHHMM. Omit it to request the latest upstream slot. Official parameter name: tm. Operation: air_amos_minute.",
      "title": "Tm"
    }
  },
  "required": [
    "stn"
  ],
  "title": "kma_apihub_url_air_amos_minute",
  "type": "object"
}
