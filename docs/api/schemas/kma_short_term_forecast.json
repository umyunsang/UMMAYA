{
  "$defs": {
    "ForecastItem": {
      "description": "A single forecast data point from the KMA short-term or ultra-short-term API.",
      "properties": {
        "base_date": {
          "title": "Base Date",
          "type": "string"
        },
        "base_time": {
          "title": "Base Time",
          "type": "string"
        },
        "category": {
          "title": "Category",
          "type": "string"
        },
        "fcst_date": {
          "title": "Fcst Date",
          "type": "string"
        },
        "fcst_time": {
          "title": "Fcst Time",
          "type": "string"
        },
        "fcst_value": {
          "title": "Fcst Value",
          "type": "string"
        },
        "nx": {
          "title": "Nx",
          "type": "integer"
        },
        "ny": {
          "title": "Ny",
          "type": "integer"
        }
      },
      "required": [
        "base_date",
        "base_time",
        "fcst_date",
        "fcst_time",
        "nx",
        "ny",
        "category",
        "fcst_value"
      ],
      "title": "ForecastItem",
      "type": "object"
    },
    "KmaShortTermForecastOutput": {
      "description": "Output from the kma_short_term_forecast tool.",
      "properties": {
        "items": {
          "items": {
            "$ref": "#/$defs/ForecastItem"
          },
          "title": "Items",
          "type": "array"
        },
        "total_count": {
          "title": "Total Count",
          "type": "integer"
        }
      },
      "required": [
        "total_count",
        "items"
      ],
      "title": "KmaShortTermForecastOutput",
      "type": "object"
    }
  },
  "$id": "https://ummaya.example/api/schemas/kma_short_term_forecast.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Input parameters for the KMA short-term forecast (단기예보) API.",
  "properties": {
    "base_date": {
      "description": "예보 발표 날짜 (YYYYMMDD). 보통 오늘. Example: 20260430.",
      "title": "Base Date",
      "type": "string"
    },
    "base_time": {
      "description": "예보 발표 시각 (HHMM, 24-hour, no separator). 유효 값 8개: 0200 / 0500 / 0800 / 1100 / 1400 / 1700 / 2000 / 2300. 각 발표 시각의 약 +10분 후 데이터 안정. 현재 시각의 직전 발표 시각 사용.",
      "title": "Base Time",
      "type": "string"
    },
    "data_type": {
      "default": "XML",
      "description": "응답 형식. XML is the official default; JSON is available if requested.",
      "enum": [
        "JSON",
        "XML"
      ],
      "title": "Data Type",
      "type": "string"
    },
    "num_of_rows": {
      "default": 290,
      "description": "결과 행 수 (default 290 = 1 격자 단기예보 full dataset). 보통 기본값 사용.",
      "minimum": 1,
      "title": "Num Of Rows",
      "type": "integer"
    },
    "nx": {
      "description": "KMA 격자 X 좌표 (1-149). locate adapter 결과의 coords.nx 를 그대로 전달. Do not substitute a memorized city example.",
      "maximum": 149,
      "minimum": 1,
      "title": "Nx",
      "type": "integer"
    },
    "ny": {
      "description": "KMA 격자 Y 좌표 (1-253). nx 와 함께 locate 으로 받음. Do not substitute a memorized city example.",
      "maximum": 253,
      "minimum": 1,
      "title": "Ny",
      "type": "integer"
    },
    "page_no": {
      "default": 1,
      "description": "페이지 번호 (1-based, default 1). 보통 기본값.",
      "minimum": 1,
      "title": "Page No",
      "type": "integer"
    }
  },
  "required": [
    "base_date",
    "base_time",
    "nx",
    "ny"
  ],
  "title": "kma_short_term_forecast",
  "type": "object"
}
