{
  "$defs": {
    "_VerifiedCollectionSchema": {
      "description": "Output schema used by legacy ToolExecutor.dispatch validation.",
      "properties": {
        "items": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "title": "Items",
          "type": "array"
        },
        "kind": {
          "title": "Kind",
          "type": "string"
        },
        "total_count": {
          "title": "Total Count",
          "type": "integer"
        }
      },
      "required": [
        "kind",
        "items",
        "total_count"
      ],
      "title": "_VerifiedCollectionSchema",
      "type": "object"
    }
