    "crno": {
      "description": "Corporate registration number.",
      "minLength": 1,
      "title": "Crno",
      "type": "string"
    },
    "num_of_rows": {
      "default": 10,
      "description": "Rows per page.",
      "maximum": 100,
      "minimum": 1,
      "title": "Num Of Rows",
      "type": "integer"
    },
    "page_no": {
      "default": 1,
      "description": "Page number.",
      "minimum": 1,
      "title": "Page No",
      "type": "integer"
    }
  },
  "required": [
    "crno",
    "biz_year"
