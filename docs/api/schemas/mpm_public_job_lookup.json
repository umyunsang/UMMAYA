      "title": "Num Of Rows",
      "type": "integer"
    },
    "page_no": {
      "default": 1,
      "description": "Page number.",
      "minimum": 1,
      "title": "Page No",
      "type": "integer"
    },
    "pblanc_ty": {
      "default": "e01",
      "description": "Notice type code.",
      "minLength": 1,
      "title": "Pblanc Ty",
      "type": "string"
    },
    "sort_order": {
      "default": "내림차순",
      "description": "Sort order.",
      "minLength": 1,
      "title": "Sort Order",
      "type": "string"
    }
