# UMMAYA .dockerignore — FR-A05
# Keep the build context small so the runtime image stays <= 2 GB.
# Everything listed here is excluded from `docker build` context.

# Version control
.git
.gitignore
.gitattributes

# Virtual environments + caches
.venv
.pytest_cache
.mypy_cache
.ruff_cache
__pycache__
*.py[cod]
*$py.class

# Test + spec + docs (not needed at runtime)
tests/
specs/
docs/
.specify/

# Spec-driven force-include carve-outs — pyproject.toml
# [tool.hatch.build.targets.wheel.force-include] bundles canonical files
# into the wheel that hatchling resolves at build time
# (it fails with FileNotFoundError if absent from the build context):
#   - docs/plugins/security-review.md → ummaya/_canonical/security-review.md
#   - tests/fixtures/plugin_validation/checklist_manifest.yaml → ummaya/_canonical/...
#   - specs/2802-public-doc-harness/contracts/document-tools.schema.json
#     → ummaya/_canonical/document-tools.schema.json
# Negate the broad excludes above for these leaves so they ship as wheel
# resources in production images. Total carve-out is small; preserves the
# SC-1 ≤ 2 GB image budget.
!docs/plugins/
!docs/plugins/security-review.md
!specs/
!specs/2802-public-doc-harness/
!specs/2802-public-doc-harness/contracts/
!specs/2802-public-doc-harness/contracts/document-tools.schema.json
!tests/fixtures/
!tests/fixtures/plugin_validation/
!tests/fixtures/plugin_validation/checklist_manifest.yaml

# CI / tooling
.github/
.claude/
.vscode/
.idea/

# Node artifacts (kept out of Python image)
node_modules/

# Logs + ephemeral files
*.log
*.pid
*.swp
.DS_Store

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Environment files (never bake secrets into the image)
.env
.env.*
secrets/
