#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
# Spec 2522 T042 — TUI PTY smoke scenario 1: 부산 날씨 (US1)
#
# Pattern: scripts/tui-tmux-capture.sh (tmux capture-pane, NOT asciinema-in-asciinema)
# Memory: feedback_debug_infra_rebuild — wait_for_pane <regex> <deadline>, no hardcoded sleep
#
# Verification targets:
#   1. Boot: "tool_registry: N entries verified"
#   2. Branding: "KOSMOS"
#   3. Input accepted (query text visible in pane)
#   4. Tool dispatched: kma_short_term_forecast or kma_current_observation single call
#   5. Tool result visible: "⎿" prefix (CC result line pattern) + actual data
#   6. LLM answer completed (streaming indicator disappears)
#   7. No "invalid_params" error
#
# Sourced by tui-tmux-capture.sh — helpers available:
#   wait_for_pane, snapshot_pane, send_text_pane, send_enter_pane, send_ctrlc_pane

# Stage A1: Wait for backend boot
wait_for_pane "tool_registry: [0-9]+ entries verified" 45
snapshot_pane "boot"

# Stage A2: Wait for KOSMOS branding / REPL idle
wait_for_pane "KOSMOS" 20
snapshot_pane "branding"

# Stage B: Submit the query — small sleep to let pane refresh before snapshot
send_text_pane "부산 날씨 알려줘"
sleep 0.5
snapshot_pane "input-typed"
send_enter_pane
sleep 0.5
snapshot_pane "input-submitted"

# Stage C1: Wait for thinking/streaming indicator (confirms LLM received query)
# "Thinking" or "Manifesting" or "Billowing" or "Lollygagging" = K-EXAONE streaming
wait_for_pane "(Thinking|Manifesting|Billowing|Lollygagging|∴|·|✻)" 30
snapshot_pane "streaming-start"

# Stage C2: Wait for tool call to appear — kma adapter dispatched
# K-EXAONE picks kma_short_term_forecast or kma_current_observation for weather
wait_for_pane "(kma_|lookup)" 90
snapshot_pane "tool-dispatched"

# Stage C3: Wait for tool result — "⎿" is the CC result-row prefix
# This proves the tool returned data (not hanging or errored)
wait_for_pane "⎿" 60
snapshot_pane "tool-result"

# Stage D: Wait for LLM final answer — extended budget for K-EXAONE post-tool reasoning
# K-EXAONE may do a second reasoning pass after tool result (30-90s additional)
# Gate on weather-specific content OR temperature digits from forecast data
# "TMP" appears in the raw tool result already visible in pane (fcst_value=17)
# "17" + "°" together, or Korean weather summary text
wait_for_pane "(°C|℃|기온|현재|온도|강수량|습도|흐림|맑음|구름|바람|precipitation|temperature)" 180
snapshot_pane "weather-answer"

# Stage E: Final snapshot after weather answer visible
snapshot_pane "final-before-quit"

# Quit cleanly
send_text_pane "/quit"
send_enter_pane
