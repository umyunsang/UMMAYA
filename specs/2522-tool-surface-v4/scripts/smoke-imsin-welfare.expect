#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
# Spec 2522 T045 — TUI PTY smoke scenario 4: 임신·출산 복지 (US4)
#
# Pattern: scripts/tui-tmux-capture.sh (tmux capture-pane, NOT asciinema-in-asciinema)
# Memory: feedback_debug_infra_rebuild — wait_for_pane <regex> <deadline>, no hardcoded sleep
#
# Verification targets:
#   1. Boot: "tool_registry: N entries verified"
#   2. Branding: "KOSMOS"
#   3. Input accepted: "임신·출산 복지서비스" submitted
#   4. mohw_welfare_eligibility_search(life_array="007") dispatched — camelCase serialize
#   5. callTp=L + srchKeyCode=003 auto-injected (not in pydantic input)
#   6. UTF-8 XML response parsed: resultCode=0, totalCount >= 21
#   7. LLM response mentions welfare services (복지, 서비스, 지원, 출산, 임신)
#   8. No "invalid_params" error visible
#   9. No "Layer3GateViolation" in output (real handle() reached)
#
# KOSMOS_DATA_GO_KR_API_KEY must be set in the caller environment for live call.
# Without it the adapter raises ConfigurationError — smoke catches + logs WARN.
#
# Sourced by tui-tmux-capture.sh — helpers available:
#   wait_for_pane, snapshot_pane, send_text_pane, send_enter_pane,
#   send_ctrlc_pane, send_keys_pane

# ── Stage A1: Backend boot ────────────────────────────────────────────────────
wait_for_pane "tool_registry: [0-9]+ entries verified" 60
snapshot_pane "boot"

# ── Stage A2: KOSMOS branding ─────────────────────────────────────────────────
wait_for_pane "KOSMOS" 20
snapshot_pane "branding"

# ── Stage B: Submit welfare query ─────────────────────────────────────────────
# US4 target: K-EXAONE should dispatch mohw_welfare_eligibility_search with
# life_array="007" (임신·출산 life-stage code).
send_text_pane "임신·출산 복지서비스 알려줘"
snapshot_pane "input-typed"
send_enter_pane
snapshot_pane "input-submitted"

# ── Stage C: Wait for tool dispatch ─────────────────────────────────────────
# K-EXAONE reasoning can take 30-90s for FriendliAI Serverless.
# Gate on: mohw dispatch marker OR welfare keyword in LLM response.
# Pattern covers tool call markers (●/⏺) + welfare keywords.
wait_for_pane "(mohw_welfare|welfare|복지|출산|임신|지원|보조금|혜택)" 90 || {
  echo "[SMOKE WARN] no tool dispatch or welfare response within 90s" >&2
}
snapshot_pane "response-partial"

# ── Stage D: Wait for turn completion ────────────────────────────────────────
# Gate on input prompt re-appearing after assistant stream finishes.
wait_for_pane "(>|●|⏺|입력|Input)" 30 || {
  echo "[SMOKE WARN] turn completion indicator not seen within 30s" >&2
}
snapshot_pane "response-complete"

# ── Stage E: Check for error conditions (non-fatal — captures for evidence) ──
# These patterns indicate the OLD stub (Layer3GateViolation) is still wired.
# If present this is a critical regression (T025 register_all.py not updated).
final_pane=$(tmux capture-pane -t "$TMUX_SESSION" -p 2>/dev/null || true)
if echo "$final_pane" | grep -qE "Layer3GateViolation|auth_required"; then
  echo "[SMOKE FAIL] Layer3GateViolation or auth_required detected — old stub still wired (register_all.py not updated to mohw.welfare_eligibility_search)" >&2
fi

# ── Stage F: Final capture ───────────────────────────────────────────────────
snapshot_pane "final-before-quit"

# ── Stage G: Graceful quit ────────────────────────────────────────────────────
send_ctrlc_pane
# 1s settle: signal delivery (process-signal settle, not latency guess)
sleep 1
send_ctrlc_pane
snapshot_pane "quit"
