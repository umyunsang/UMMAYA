#!/usr/bin/env expect
# SPDX-License-Identifier: Apache-2.0
# Layer 3/5 text smoke for text + LF submitted in one stdin chunk.

set timeout 30
set env(UMMAYA_BACKEND_CMD) "sleep 60"

spawn -noecho ../bin/ummaya
expect -re {UMMAYA.*v0\.1\.14}
expect {
  -re {Choose.*text style} {
    send "\r"
    exp_continue
  }
  -re {Run.*/login} {}
  -re {Not.*logged.*in} {}
}
send -- "/login\n"
expect -re {API.*key:}
exit 0
