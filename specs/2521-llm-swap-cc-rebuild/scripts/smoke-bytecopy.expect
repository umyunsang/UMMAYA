#!/usr/bin/expect -f
# SPDX-License-Identifier: Apache-2.0
# Spec 2521 — interactive PTY scenario verifying that the 3419-LOC byte-copy
# of services/api/claude.ts + 3 swap commits did not regress TUI boot or
# interactive surface. The byte-copied claude.ts has zero callers in tui/src
# (verified via grep for verifyApiKey / queryHaiku / queryWithModel) so the
# expectation is identical-to-baseline behavior. This script captures the
# evidence that the dead-code byte-copy didn't accidentally re-import
# something that explodes at module-load time.
#
# AGENTS.md hard rule: PRs touching tui/src/** must commit Layer 3 PTY +
# Layer 4 vhs artefacts under specs/<feature>/.
#
# Output: stdout PTY text log → captured by `script` wrapper to
# specs/2521-llm-swap-cc-rebuild/smoke-bytecopy-pty.txt.

set timeout 30
log_user 1

set REPO_ROOT [exec git -C [file dirname [file normalize [info script]]] rev-parse --show-toplevel]

# Direct spawn (no bash -c wrapper) preserves the controlling PTY to the
# child so the TUI's isInteractive()/isatty() detection treats the session
# as a real terminal. Wrapping with bash -c caused KOSMOS to fall into
# headless print-mode and exit immediately.
cd "$REPO_ROOT/tui"
spawn bun run tui

# 1. Wait for backend boot (tool_registry init logged at boot — proves the
# byte-copied claude.ts module graph loaded without crashing). The Ink
# screen-clear ANSI sequence afterwards repaints over the boot log so we
# anchor on this earlier emission instead of the rendered branding.
expect {
  -re "tool_registry: \\d+ entries verified" {
    puts "\n\[CHECK\] backend boot OK — tool registry initialised"
  }
  timeout {
    puts "\n\[FAIL\] timed out waiting for tool_registry init"
    exit 1
  }
}

# 2. Idle a moment so the screen finishes settling
sleep 2

# 3. Slash command surface — send /help
send "/help\r"
sleep 3
puts "\n\[CHECK\] /help dispatched (no module-load-time crash)"

# 4. Exit cleanly with two Ctrl+C
send "\003"
sleep 1
send "\003"

expect {
  eof {
    puts "\n\[CHECK\] clean EOF after Ctrl+C×2"
  }
  timeout {
    puts "\n\[WARN\] no EOF inside timeout — terminating"
    exit 0
  }
}
