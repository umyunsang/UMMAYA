#!/usr/bin/expect -f
# SPDX-License-Identifier: Apache-2.0
# Spec 2521 (2026-05-02) — Layer 5 verbose-mode JSON view scenario.
#
# Drives the citizen flow with ``--verbose`` so:
#   - LookupPrimitive.renderToolUseMessage(verbose=true)  → request JSON
#   - LookupPrimitive.renderToolResultMessage(verbose=true) →
#       envelope JSON + outbound HTTP trace section (cyan header)
# render directly inline in the live REPL (no Ctrl+O needed).
#
# Probe points (verifiable in timeline.txt + frame txts):
#   A. backend boot + branding
#   B. user input + submit
#   C. reasoning / spinner
#   D. ● lookup tool call paint with verbose JSON params
#   E. ⎿ envelope JSON + 외부 API 요청 #N section
#   F. final Korean answer streaming
#   G. /quit graceful exit

set timeout 240
log_user 1

set REPO_ROOT [exec git -C [file dirname [file normalize [info script]]] rev-parse --show-toplevel]
cd "$REPO_ROOT/tui"

# --verbose flag so chat-mode Messages renders renderTool*Message with
# verbose=true. Forces the new JSON view inline in the live REPL — no
# transcript toggle needed for the smoke run.
spawn bun run tui --verbose

# A. backend boot + branding.
expect {
  -re "tool_registry: \[0-9\]+ entries verified" {
    puts "\n\[A1\] backend boot"
  }
  timeout { puts "\n\[FAIL A1\] no backend boot"; exit 1 }
}
expect {
  -re "KOSMOS" { puts "\n\[A2\] branding visible" }
  timeout { puts "\n\[FAIL A2\] no branding"; exit 1 }
}

# Settle one render tick.
sleep 1

# B. user input — phrasing that nudges the LLM toward
# resolve_location (always fires Kakao API → guaranteed httpx call).
send -- "서울특별시 종로구 청와대로 1 좌표 알려줘"
sleep 1
send -- "\r"
puts "\n\[B\] input submitted"

# C. reasoning / spinner.
expect {
  -re "Symbioting|Crunched|Thinking|⏵|✽|∴" {
    puts "\n\[C\] reasoning / spinner visible"
  }
  timeout { puts "\n\[FAIL C\] no reasoning indicator"; exit 2 }
}

# D. tool call paint — ``● lookup`` plus verbose multi-line JSON in the
#    captured frames. We check just the prefix here; the JSON braces
#    are verified via post-run frame inspection (avoids tcl regex escape
#    landmines).
expect {
  -re "● lookup" {
    puts "\n\[D\] tool call paint visible"
  }
  timeout { puts "\n\[FAIL D\] no tool call ui"; exit 3 }
}

# E. envelope + outbound trace — verbose result rendering.
#    Look for the "외부 API 요청" header (cyan) the new verboseRender emits.
expect {
  -re "외부 API 요청" {
    puts "\n\[E\] outbound HTTP trace section visible"
  }
  -re "응답 envelope" {
    puts "\n\[E!\] envelope JSON header visible (no outbound trace yet)"
  }
  timeout { puts "\n\[WARN E\] no envelope/outbound section captured (LLM may not have called a Live adapter)" }
}

# F. Korean answer streaming.
expect {
  -re "강수|날씨|기온|하늘|구름|맑|흐림" {
    puts "\n\[F\] Korean answer started streaming"
  }
  timeout { puts "\n\[WARN F\] no Korean answer captured" }
}

# Settle the answer.
sleep 8

# G. graceful quit.
send -- "/quit\r"
expect {
  eof { puts "\n\[G\] quit ok (eof)" }
  timeout { puts "\n\[G\] quit timeout — sending C-c"; send -- "\003\003"; expect eof }
}
