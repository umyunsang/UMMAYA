#!/usr/bin/expect -f
# SPDX-License-Identifier: Apache-2.0
# Spec 2521 (2026-05-02) — Layer 5 reproduction for the user-reported
# multi-tool layout glitch: "부산 날씨 어때 지금?" prompt forces K-EXAONE
# into multiple lookup attempts and the user sees 4 ● lookup() calls
# without ⎿ result rows + thinking appearing below the tools.
#
# Capture goal: enumerate every distinct screen state across the entire
# turn so the UI/UX bug (missing spinner? missing result? bad spacing?)
# can be pinpointed by reading frames in order.

set timeout 240
log_user 1

set REPO_ROOT [exec git -C [file dirname [file normalize [info script]]] rev-parse --show-toplevel]
cd "$REPO_ROOT/tui"

spawn bun run tui

# Boot.
expect {
  -re "tool_registry: \[0-9\]+ entries verified" { puts "\n\[A1\] backend boot" }
  timeout { puts "\n\[FAIL A1\] no boot"; exit 1 }
}
expect {
  -re "KOSMOS" { puts "\n\[A2\] branding" }
  timeout { puts "\n\[FAIL A2\]"; exit 1 }
}

sleep 1

send -- "부산 날씨 어때 지금 ?"
sleep 1
send -- "\r"
puts "\n\[B\] submitted"

# Sleep long enough to capture the whole multi-tool turn — K-EXAONE on
# FriendliAI averages 30-90s for a 4-tool weather query. We don't gate on
# the answer text because the *layout glitch happens during streaming*,
# not at end-of-turn — we want every intermediate paint state.
sleep 90

# Quit.
send -- "/quit\r"
expect {
  eof { puts "\n\[G\] quit ok" }
  timeout { send -- "\003\003"; expect eof }
}
