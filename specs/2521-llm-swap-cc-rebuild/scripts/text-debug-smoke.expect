#!/usr/bin/expect -f
# Smoke 시나리오 — 부팅 + /quit. 인프라 검증용.
set timeout 30
log_user 1
set REPO_ROOT [exec git -C [file dirname [file normalize [info script]]] rev-parse --show-toplevel]
cd "$REPO_ROOT/tui"
spawn bun run tui
expect {
  -re "tool_registry: \[0-9\]+ entries verified" {
    puts "\n\[OK\] backend boot"
  }
  timeout { puts "\n\[FAIL\] no backend boot log"; exit 1 }
}
expect {
  -re "KOSMOS" { puts "\n\[OK\] branding visible" }
  timeout { puts "\n\[FAIL\] no branding"; exit 1 }
}
sleep 2
send -- "/quit\r"
expect {
  eof { puts "\n\[OK\] quit eof" }
  timeout { send -- "\003\003"; expect eof }
}
