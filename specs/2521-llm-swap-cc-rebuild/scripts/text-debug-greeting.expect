#!/usr/bin/expect -f
# Spec 2521 short-prompt scenario for the streaming-pacing verification.
# A bare "안녕하세요" doesn't need any tool calls, so the LLM goes straight
# to answer-streaming — letting Layer 5 capture the chunk granularity.

set timeout 90
log_user 1
set REPO_ROOT [exec git -C [file dirname [file normalize [info script]]] rev-parse --show-toplevel]
cd "$REPO_ROOT/tui"
spawn bun run tui

expect {
  -re "tool_registry: \[0-9\]+ entries verified" { puts "\n\[A1\] backend boot" }
  timeout { puts "\n\[FAIL A1\] no backend boot"; exit 1 }
}
expect {
  -re "KOSMOS" { puts "\n\[A2\] branding" }
  timeout { puts "\n\[FAIL A2\] no branding"; exit 1 }
}

sleep 1
send -- "안녕하세요"
sleep 0.5
send -- "\r"

expect {
  -re "Symbioting|Puttering|Beaming|Cogitating|Crunched|Thinking|✻|✶" {
    puts "\n\[B\] reasoning"
  }
  timeout { puts "\n\[FAIL B\] no reasoning"; exit 2 }
}

expect {
  -re "안녕|반갑|도움|드릴|드리겠|코스모스|인사|환영" { puts "\n\[C\] korean answer streaming" }
  timeout { puts "\n\[FAIL C\] no answer"; exit 3 }
}

sleep 5
send -- "/quit\r"
expect {
  eof { puts "\n\[D\] quit eof" }
  timeout { send -- "\003\003"; expect eof }
}
