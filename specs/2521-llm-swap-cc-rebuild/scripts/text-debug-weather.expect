#!/usr/bin/expect -f
# SPDX-License-Identifier: Apache-2.0
# Spec 2521 — Layer 5 weather scenario for `scripts/tui-text-debug.sh`.
#
# Drives a normal user flow: 사용자가 서울 날씨를 묻고, internal BM25
# 가 hide 되며, 도구 호출 + 답변까지 streaming. asciinema rec wraps
# this expect process so every PTY byte is captured into raw.cast;
# cast_to_frames.py later replays through pyte to produce per-frame
# plain-text cell-grid snapshots (frame_NNNN_t<sec>_<sha>.txt).
#
# Flow anchors (verifiable in the resulting timeline.txt):
#   A. branding   — KOSMOS / ✻ / tool_registry verified
#   B. input typed
#   C. reasoning  — Symbioting / Crunched / ⏵ spinner
#   D. tool call  — ● lookup(fetch:resolve_location|kma_*|hira_*)
#   E. answer     — 한국어 답변 streaming (강수/날씨/기온/하늘)
#   F. quit       — /quit acknowledged

set timeout 180
log_user 1

set REPO_ROOT [exec git -C [file dirname [file normalize [info script]]] rev-parse --show-toplevel]
cd "$REPO_ROOT/tui"

spawn bun run tui

# A. branding
expect {
  -re "tool_registry: \[0-9\]+ entries verified" {
    puts "\n\[A1\] backend boot"
  }
  timeout { puts "\n\[FAIL A1\] no backend boot"; exit 1 }
}
expect {
  -re "KOSMOS" { puts "\n\[A2\] branding visible" }
  timeout { puts "\n\[FAIL A2\] no branding"; exit 1 }
}

# Settle one render tick.
sleep 1

# B. input — 한 글자씩 보내 IME / paste-burst 회귀 회피.
send -- "오늘 서울 날씨 알려줘"
sleep 1
send -- "\r"
puts "\n\[B\] input submitted"

# C. reasoning / spinner — internal BM25 hide 가 작동하면 도구 ui 가
# 즉시 안 뜨고 spinner 만 노출.
expect {
  -re "Symbioting|Crunched|Thinking|⏵" {
    puts "\n\[C\] reasoning / spinner visible"
  }
  timeout { puts "\n\[FAIL C\] no reasoning indicator"; exit 2 }
}

# D. first tool call — ● 으로 시작하는 도구 호출 ui.
expect {
  -re "● lookup|● fetch|● resolve_location|● kma_" {
    puts "\n\[D\] first tool call visible"
  }
  timeout { puts "\n\[FAIL D\] no tool call ui"; exit 3 }
}

# E. Korean answer streaming.
expect {
  -re "강수|날씨|기온|하늘|구름|맑|흐림" {
    puts "\n\[E\] korean answer started streaming"
  }
  timeout { puts "\n\[FAIL E\] no korean answer"; exit 4 }
}

# Let the answer settle.
sleep 6

# F. graceful quit.
send -- "/quit\r"
expect {
  eof { puts "\n\[F\] quit ok (eof)" }
  timeout { puts "\n\[F\] quit timeout — sending C-c"; send -- "\003\003"; expect eof }
}
