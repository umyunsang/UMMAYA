[0.012, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[9A1.\u001b[1C\u001b[1m다른 공공 서비스\u001b[22m:\u001b[1C병원\u001b[1C검색(hira_hospital_search)\u001b[1C도구는\u001b[1C사용\u001b[1C가능\r\u001b[2C\u001b[1B2\u001b[2C\u001b[1m일반적인 봄 날씨 정보\u001b[22m:\u001b[1C5월 서울은 보통 맑고 온화한 날씨 \u001b[1C    \u001b[1C    \r\u001b[2C\u001b[1B3\u001b[2C\u001b[1m직접 확인\u001b[22m: 다른 날씨 앱에서 실시간 정보 확인      \u001b[1C    \r\u001b[2C\u001b[1B  \u001b[1C          \u001b[1C    \u001b[1C    \u001b[1C      \u001b[1C      \u001b[1C    \u001b[1C    \r\u001b[2C\u001b[1B어떤\u001b[1C방향으로\u001b[1C도움을\u001b[1C드리면\u001b[1C좋을까요?\u001b[1C날씨\u001b[1C외에\u001b[1C다른\u001b[1C정보가\u001b[1C필요하신지,\u001b[1C아니면\u001b[1C날씨\u001b[1C관련\u001b[1C다른\u001b[1C질문이\u001b[1C있으신지\u001b[1C알려주세요.\r\u001b[1B                                                                                                                                                                                                        \r\u001b[1B\u001b[38;2;153;153;153m✻\u001b[39m \u001b[38;2;153;153;153mChurned for 43s\r\u001b[1B\u001b[39m                                                                              "]
