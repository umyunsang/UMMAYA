[0.050, "o", "\u001b[?2026h\u001b[2D\u001b[3B\r\u001b[2C\u001b[8A-\u001b[1C날씨\u001b[1C관련\u001b[1C도구들(kma_forecast_fetch,\u001b[1Ckma_short_term_forecast,\u001b[1Ckma_current_observation)이\u001b[1C유효한\u001b[1C매개변수를\u001b[1C받아들이지\u001b[1C못함\r\u001b[4C\u001b[1B오늘\u001b[1C날짜: 2026년 5월 1일           \u001b[1C                        \u001b[1C                          \u001b[1C      \u001b[1C          \u001b[1C          \u001b[1C    \r\u001b[2C\u001b[1B \u001b[1C    \u001b[1C     \u001b[1C      \u001b[1C   \u001b[1C   \r\u001b[2C\u001b[1B\u001b[1m제안드리는 대안:\r\u001b[1B\u001b[22m                                                                                                                                                                                                        \r\u001b[1B\u001b[38;2;136;136;136m───────────────────────────────────────────────────────────────────────────────────────────────────────────────────"]
