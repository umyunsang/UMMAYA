#!/usr/bin/env expect -f
# Sanity check: does /help even work?
set timeout 30

set spec_dir [file dirname [file dirname [info script]]]
set log_path "$spec_dir/debug-help.txt"

spawn script -q $log_path bash -c "cd tui && bun run tui"

expect {
  -re ".*KOSMOS.*" { puts "✓ KOSMOS branding observed" }
  timeout { exit 1 }
}

sleep 3

puts "Sending /help"
send -- "/help\r"

sleep 8

puts "Sending Ctrl-C"
send -- "\003"
sleep 1
send -- "\003"
expect eof
