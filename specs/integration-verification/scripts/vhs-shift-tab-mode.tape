# Shift+Tab mode cycle (default → auto-accept → bypass)
Output specs/integration-verification/frames/vhs-21-mode.gif
Output specs/integration-verification/frames/vhs-21-mode.txt
Set Shell "bash"
Set FontSize 14
Set Width 1600
Set Height 900
Set Theme "TokyoNightStorm"
Hide
Type "cd /Users/um-yunsang/KOSMOS/tui && KOSMOS_ONBOARDING_AUTO_COMPLETE=1 bun run tui"
Enter
Sleep 5s
Show
