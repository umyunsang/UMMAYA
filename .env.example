# UMMAYA environment template
# Copy to `.env` (which is a gitignored symlink to your secrets store) and fill in values.
# See docs/configuration.md for the authoritative registry.
# All `<redacted>` placeholders must be replaced with real values before running.
#
# Format note: inline `# ...` on the same line as a value is NOT treated as a
# comment by `src/ummaya/_dotenv.py` — the parser strips quotes but does not
# strip trailing `#` comments. Keep all commentary on its own line ABOVE the
# key so that a bare `cp .env.example .env` produces truly empty values and
# triggers `ummaya.config.guard` with the single-line remediation message.

# --- User session key (not an operator/Infisical secret) ---
# Public CLI users enter this through /login. Source/self-hosted developers may
# export it locally for backend-only tests. Do not store it in Infisical release
# or operator environments.
# UMMAYA_FRIENDLI_TOKEN=

# --- Operator-managed live adapter keys ---
# Public CLI users should not be asked for these keys. Hosted/operator
# deployments keep them server-side; source/self-hosted live-adapter developers
# may set them locally. Never package maintainer key values into wheels, sdists,
# docs, or frontend assets.
# consumed by ummaya.settings.UmmayaSettings.kakao_api_key
# UMMAYA_KAKAO_API_KEY=<redacted>
# consumed by ummaya.settings.UmmayaSettings.data_go_kr_api_key
# UMMAYA_DATA_GO_KR_API_KEY=<redacted>

# --- Release live-adapter gateway ---
# Public release users should not need to set Kakao/data.go.kr keys. Packaged
# CLI executions use the operator-managed gateway in auto mode; source-tree
# developers can force direct mode when testing local live adapters.
# UMMAYA_LIVE_ADAPTER_MODE=auto
# UMMAYA_LIVE_ADAPTER_PROXY_URL=https://ummaya-live-gateway-ygjh3ipzqq-du.a.run.app/v1/adapters
# UMMAYA_LIVE_ADAPTER_PROXY_TIMEOUT_SECONDS=30
# Optional private/self-hosted gateway token. Do not set for public releases.
# UMMAYA_LIVE_ADAPTER_PROXY_TOKEN=<redacted>
# Optional server-side token enforced by ummaya-live-gateway when set.
# UMMAYA_LIVE_ADAPTER_GATEWAY_TOKEN=<redacted>
# Server-side abuse controls for ummaya-live-gateway.
# UMMAYA_LIVE_ADAPTER_GATEWAY_RATE_LIMIT_PER_MINUTE=120
# UMMAYA_LIVE_ADAPTER_GATEWAY_MAX_BODY_BYTES=65536

# --- Optional fallback (resolve_location.py logs-and-skips when unset) ---
# consumed by ummaya.settings.UmmayaSettings.juso_confm_key
# UMMAYA_JUSO_CONFM_KEY=<redacted>
# consumed by ummaya.settings.UmmayaSettings.sgis_key
# UMMAYA_SGIS_KEY=<redacted>
# consumed by ummaya.settings.UmmayaSettings.sgis_secret
# UMMAYA_SGIS_SECRET=<redacted>

# --- Required in prod only (conditional) ---
# consumed by ummaya.observability.langfuse (#501)
LANGFUSE_PUBLIC_KEY=<redacted>
# consumed by ummaya.observability.langfuse (#501)
LANGFUSE_SECRET_KEY=<redacted>
# consumed by ummaya.observability.otel (#501)
UMMAYA_OTEL_ENDPOINT=<redacted>

# --- Optional (defaults apply) ---
# activation flag: dev | ci | prod (default dev)
# UMMAYA_ENV=dev
# consumed by ummaya.llm.config.LLMClientConfig.base_url
# UMMAYA_FRIENDLI_BASE_URL=<redacted>
# consumed by ummaya.llm.config.LLMClientConfig.model
# UMMAYA_FRIENDLI_MODEL=<redacted>
# consumed by ummaya.llm.config.LLMClientConfig.session_budget
# UMMAYA_LLM_SESSION_BUDGET=<redacted>
# consumed by ummaya.settings.UmmayaSettings.lookup_topk; clamped [1, 20]
# UMMAYA_LOOKUP_TOPK=5
# consumed by ummaya.settings.UmmayaSettings.nmc_freshness_minutes; clamped [1, 1440]
# UMMAYA_NMC_FRESHNESS_MINUTES=30
# consumed by ummaya.cli.config.CLIConfig.history_size
# UMMAYA_CLI_HISTORY_SIZE=<redacted>
# consumed by ummaya.cli.config.CLIConfig.show_usage
# UMMAYA_CLI_SHOW_USAGE=<redacted>
# consumed by ummaya.cli.config.CLIConfig.welcome_banner
# UMMAYA_CLI_WELCOME_BANNER=<redacted>
# consumed by ummaya.cli.themes.load_theme (alias for UMMAYA_THEME)
# UMMAYA_CLI_THEME=<redacted>
# consumed by ummaya.cli.themes.load_theme
# UMMAYA_THEME=<redacted>

# --- Override pattern (escape hatch) ---
# per-tool override, e.g. UMMAYA_KOROAD_ACCIDENT_SEARCH_API_KEY; see docs/configuration.md
# UMMAYA_<TOOL_ID>_API_KEY=<redacted>

# --- Deprecated (scheduled for removal) ---
# legacy global fallback — do not set in new installs; consumed by ummaya.permissions.credentials (global fallback)
# UMMAYA_API_KEY=<redacted>

# OTLP Collector (spec 028)
# consumed by docker-compose.dev.yml — host port of the otelcol OTLP HTTP receiver
UMMAYA_OTEL_COLLECTOR_PORT=4318
# consumed by infra/otel-collector/config.yaml — base OTLP URL (collector appends /v1/traces automatically)
UMMAYA_LANGFUSE_OTLP_ENDPOINT=http://langfuse-web:3000/api/public/otel
# consumed by infra/otel-collector/config.yaml — Basic <base64(pk-xxx:sk-xxx)> for Langfuse OTLP auth (empty = anonymous)
UMMAYA_LANGFUSE_OTLP_AUTH_HEADER=
